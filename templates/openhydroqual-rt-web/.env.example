# Turn on queue execution from API to worker
ASYNC_EXECUTION=true

# Redis on EC2 / ElastiCache (or local Redis)
BROKER_URL=redis://localhost:6379/0
RESULT_BACKEND=redis://localhost:6379/1

# OHQuery endpoint (ECS service / EC2 / internal ALB)
OHQUERY_BASE_URL=http://localhost:8080

# For local smoke without OHQuery service
MOCK_OHQUERY=true
OHQUERY_TIMEOUT_SECONDS=30
